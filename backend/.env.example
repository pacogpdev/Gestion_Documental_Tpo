# ── Database ───────────────────────────────────────────────────────
# Development (SQLite):
DATABASE_URL=sqlite:///backend/test.db
# Production (Azure SQL Server):
# DATABASE_URL=mssql+pymssql://user:password@pedro-ortiz-sql.database.windows.net/pedro-ortiz-db_2
# NOTE: URL-encode special characters in the password (e.g. $ → %24, % → %25, : → %3A, ) → %29)

# ── Azure Entra ID (opcional para desarrollo local) ────────────────
ENTRA_ID_TENANT_ID=
ENTRA_ID_CLIENT_ID=
ENTRA_ID_JWKS_URL=

# ── Azure AI Document Intelligence (legacy fallback) ────────────────
AZURE_AI_ENDPOINT=
AZURE_AI_KEY=

# ── Azure AI Content Understanding (reemplaza Document Intelligence) ─
AZURE_CONTENT_ENDPOINT=
AZURE_CONTENT_KEY=

# ── Azure Blob Storage (persistencia de PDFs) ──────────────────────
# Connection string completa de la cuenta de storage (Azure Portal → Access keys)
AZURE_STORAGE_CONNECTION_STRING=
# Contenedor destino para los PDFs de facturas
AZURE_STORAGE_CONTAINER=facturas-proveedores
